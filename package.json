{
  "name": "evivi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "api:dev": "npm --prefix apps/api run dev",
    "api:build": "npm --prefix apps/api run build",
    "api:test": "npm --prefix apps/api run test",
    "api:generate": "npm --prefix apps/api run prisma:generate",
    "api:migrate": "npm --prefix apps/api run prisma:migrate",
    "api:seed": "npm --prefix apps/api run db:seed",
    "backend:check": "npm run api:build && npm run api:test",
    "backend:docker:build": "docker compose -f infra/docker-compose.yml build api",
    "backend:docker:logs": "docker compose -f infra/docker-compose.yml logs -f api",
    "backend:up": "docker compose -f infra/docker-compose.yml up -d postgres redis",
    "backend:down": "docker compose -f infra/docker-compose.yml down",
    "db:up": "docker compose -f infra/docker-compose.yml up -d",
    "db:down": "docker compose -f infra/docker-compose.yml down",
    "mobile:start": "npm --prefix apps/mobile run start",
    "mobile:web": "npm --prefix apps/mobile run web"
  }
}
